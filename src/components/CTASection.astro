---
interface CTA {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  primary?: CTA;
  secondary?: CTA;
}

const {
  eyebrow = "Start with feedback",
  title,
  body,
  primary = { label: "Get Free Feedback", href: "/contact" },
  secondary,
} = Astro.props;
---

<section class="container-page section-tight">
  <div class="cta-panel">
    <div>
      <p class="label-eyebrow">{eyebrow}</p>
      <h2 class="heading-tight text-balance" style="margin-top: 0.75rem;">{title}</h2>
      <p class="text-muted text-pretty" style="max-width: 760px; margin-top: 1rem;">{body}</p>
    </div>
    <div class="hero-actions" style="margin-top: 0;">
      {primary && <a class="primary-pill" href={primary.href}>{primary.label}</a>}
      {secondary && <a class="outline-pill" href={secondary.href}>{secondary.label}</a>}
    </div>
  </div>
</section>

