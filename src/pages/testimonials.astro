---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CTASection from "../components/CTASection.astro";
import SectionLabel from "../components/SectionLabel.astro";
import MediaSlot from "../components/MediaSlot.astro";
import { testimonialPlaceholders, testimonialThemes } from "../data/testimonials";
import { breadcrumbSchema } from "../data/schema";

const schema = [breadcrumbSchema([{ name: "Home", path: "/" }, { name: "Testimonials", path: "/testimonials" }])];
---

<BaseLayout
  title="Testimonials - Proof Matters. Trust Is Earned."
  description="What clients, partners, and business owners say about working with Motion."
  canonical="/testimonials"
  schema={schema}
>
  <Hero
    compact
    eyebrow="Testimonials"
    title="Proof matters. Trust is earned."
    subtitle="See what clients, partners, and business owners say about working with Motion."
    primary={{ label: "Start With Free Feedback", href: "/contact" }}
  />

  <section class="container-page section-tight">
    <SectionLabel number="01" label="Themes" />
    <div class="tag-list" style="margin-top: 1.5rem;">
      {testimonialThemes.map((theme) => <span class="tag micro">#{theme}</span>)}
    </div>
  </section>

  <section class="container-page section">
    <SectionLabel number="02" label="Client quotes" />
    <div class="grid-3" style="margin-top: 2rem;">
      {testimonialPlaceholders.map((item) => (
        <article class="surface-card card-pad">
          <p class="text-pretty">"{item.quote}"</p>
          <div style="margin-top: 1.5rem; border-top: 1px solid var(--line); padding-top: 1rem;">
            <p style="margin: 0;">{item.person}</p>
            <p class="form-note">{item.business} · {item.industry} · {item.service}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container-page section">
    <SectionLabel number="03" label="Video stories" />
    <div class="grid-3" style="margin-top: 2rem;">
      {[1, 2, 3].map((item) => <MediaSlot label="Video testimonial placeholder" />)}
    </div>
  </section>

  <CTASection
    eyebrow="Become the next story"
    title="Want to become the next growth story?"
    body="Start with free feedback. We'll show you the leaks, the opportunities, and the priority order."
  />
</BaseLayout>

